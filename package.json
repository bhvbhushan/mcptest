{
  "name": "mcp-quality-gate",
  "version": "0.1.1",
  "description": "Quality gate for MCP servers — compliance, security, and efficiency testing",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "mcp-quality-gate": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm run build && npm test"
  },
  "author": {
    "name": "Bhavya Bhushan",
    "url": "https://github.com/bhvbhushan"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bhvbhushan/mcp-quality-gate.git"
  },
  "bugs": {
    "url": "https://github.com/bhvbhushan/mcp-quality-gate/issues"
  },
  "homepage": "https://github.com/bhvbhushan/mcp-quality-gate#readme",
  "keywords": [
    "mcp",
    "mcp-server",
    "mcp-testing",
    "model-context-protocol",
    "testing",
    "compliance",
    "security",
    "quality-gate",
    "schema-validation",
    "ai-tools",
    "llm",
    "anthropic",
    "claude",
    "developer-tools",
    "static-analysis"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "commander": "^13.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
